<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.charles.watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/home/charles/.venv/bin/python</string>
        <string>/Users/home/charles/scripts/watchdog.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/home/charles</string>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>/Users/home/charles/logs/watchdog.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/home/charles/logs/watchdog.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/home/charles/.venv/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
