# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Workspace runtime data
workspace/memory.db
workspace/memory/
workspace/projects/

# Logs
logs/
*.log

# ContrPro runtime state (added 2026-05-15 when contrpro/ was first tracked
# in this repo). Source code, scripts, and the per-tier content under
# files/packages/ ARE tracked. Runtime DB, generated emails, and pycache are not.
contrpro/contrpro.db
contrpro/contrpro.db-shm
contrpro/contrpro.db-wal
contrpro/emails/
# Fly first-boot seed snapshot = a copy of the orders DB (customer data). Never commit.
contrpro/deploy/fly/seed/contrpro.db
# Empty handlers/ dir is a placeholder for future per-event handlers
contrpro/handlers/

# macOS
.DS_Store

# Local-only docs
CHARLES-CLAUDE-CODE-PROMPT.md
MAC_MIGRATION_CHECKLIST.md
openclaw_install.txt
models/
workspace/google_oauth_client.json
workspace/gmail_token.json
.aider*

# Training corpus — raw exports contain John's PII (full name, email, phone)
# and months of private conversations. NEVER commit raw drops.
training_corpus/manual_drops/
training_corpus/mac_claude_code/
training_corpus/mobile_claude/
training_corpus/windows_cowork/
training_corpus/_processed/
# Top-level zip drops (e.g. claude.ai data export)
/data-*.zip
# Normalized corpus JSONL files contain John's private conversations even
# after PII/credential scrubbing. Keep recipe (SPLIT.md, meta.json,
# smoke_config.yaml) tracked; keep data files local-only.
training_corpus/_normalized/*.jsonl
training_corpus/_normalized/**/train.jsonl
training_corpus/_normalized/**/valid.jsonl
training_corpus/_normalized/**/_audit_with_meta.jsonl
# LoRA adapter checkpoints — 256MB each, broken smoke artifacts. Local-only.
training_corpus/_normalized/**/smoke_adapter/
training_corpus/_normalized/**/phase3_adapter/
training_corpus/_normalized/**/*_adapter/
training_corpus/_normalized/**/*.log
# A/B test staging (just a copy of the adapter under test — local-only)
training_corpus/_normalized/**/_ab_staged/
# A/B result JSONs contain model outputs that quote training-data fragments.
# Keep them local-only.
training_corpus/_normalized/**/ab_results_*.json
training_corpus/_normalized/**/ab_run_*.log
checkpoints/
